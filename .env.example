DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/maya
XAI_API_KEY=
OPENAI_API_KEY=         # Required: for fallback + embeddings + cheap extraction calls
ANTHROPIC_API_KEY=      # Optional: secondary fallback
LITELLM_LOG=ERROR
ENVIRONMENT=local

# Telegram (optional — leave TELEGRAM_BOT_TOKEN empty to disable the channel)
TELEGRAM_BOT_TOKEN=        # From @BotFather
TELEGRAM_WEBHOOK_SECRET=   # Random string; echoed in webhook header to reject forgeries
PUBLIC_BASE_URL=           # Public HTTPS base, e.g. https://maya.up.railway.app
