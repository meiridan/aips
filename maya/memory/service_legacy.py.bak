"""Memory service: extracts facts from conversations using Grok and stores them.

Phase 2 implementation that doesn't require OpenAI (uses Grok via litellm).
Uses simple text storage + LLM-based relevance scoring instead of vector embeddings.
"""

from __future__ import annotations

import json
import uuid
from typing import Any

from sqlalchemy import select, delete
from sqlalchemy.ext.asyncio import AsyncSession, async_sessionmaker

from maya.db.models import Memory
from maya.db.session import get_sessionmaker
from maya.llm.service import LLMService
from maya.logging import get_logger

log = get_logger("maya.memory")


EXTRACT_PROMPT = """You are a fact extractor for an AI companion's memory system.

Your job: extract durable facts about the USER from the conversation below.

Rules:
- Only extract facts about the USER, not the assistant
- Each fact must be a SHORT, standalone statement (e.g. "User's name is David", "User works as a backend developer")
- Skip greetings, small talk, and ephemeral details
- Skip facts that are already obvious or generic
- If nothing worth remembering, return an empty list
- Output ONLY valid JSON, no other text

Output format:
{"facts": ["fact 1", "fact 2", ...]}

Conversation:
{conversation}

Existing facts (don't duplicate):
{existing_facts}

Output JSON:"""


class MemoryService:
    """Stores and retrieves long-term memories about the user."""
    
    def __init__(
        self,
        llm: LLMService | None = None,
        sessionmaker: async_sessionmaker[AsyncSession] | None = None,
    ):
        self.llm = llm or LLMService()
        self._sessionmaker = sessionmaker or get_sessionmaker()
    
    async def extract_and_store(
        self,
        user_id: uuid.UUID,
        companion_id: uuid.UUID,
        user_message: str,
        assistant_message: str,
    ) -> list[str]:
        """Extract facts from a single exchange and store them. Returns extracted facts."""
        # Get existing facts to avoid duplicates
        existing = await self.get_all(user_id, companion_id)
        existing_text = "\n".join(f"- {m['text']}" for m in existing[-30:]) or "(none)"
        
        conversation = f"User: {user_message}\nAssistant: {assistant_message}"
        
        prompt = EXTRACT_PROMPT.format(
            conversation=conversation,
            existing_facts=existing_text,
        )
        
        try:
            response = await self.llm.chat(
                [{"role": "user", "content": prompt}],
                model_tier="main",
                temperature=0.1,
                max_tokens=500,
                purpose="memory_extraction",
            )
            
            # Parse JSON
            response = response.strip()
            if response.startswith("```"):
                # Strip markdown code fences
                response = response.split("\n", 1)[1] if "\n" in response else response
                if response.endswith("```"):
                    response = response.rsplit("```", 1)[0]
            
            data = json.loads(response)
            facts = data.get("facts", [])
            
            if not isinstance(facts, list):
                facts = []
            
            # Filter to non-empty strings
            facts = [f.strip() for f in facts if isinstance(f, str) and f.strip()]
            
            # Store each fact
            if facts:
                async with self._sessionmaker() as session:
                    for fact_text in facts:
                        mem = Memory(
                            user_id=user_id,
                            companion_id=companion_id,
                            text=fact_text,
                        )
                        session.add(mem)
                    await session.commit()
            
            log.info(
                "memory_extracted",
                user_id=str(user_id),
                companion_id=str(companion_id),
                count=len(facts),
            )
            
            return facts
            
        except (json.JSONDecodeError, ValueError) as exc:
            log.warning("memory_extraction_failed", error=str(exc))
            return []
        except Exception as exc:
            log.error("memory_extraction_error", error=str(exc))
            return []
    
    async def get_all(
        self,
        user_id: uuid.UUID,
        companion_id: uuid.UUID,
    ) -> list[dict[str, Any]]:
        """Get all memories for a user/companion pair (chronological)."""
        async with self._sessionmaker() as session:
            stmt = (
                select(Memory)
                .where(
                    Memory.user_id == user_id,
                    Memory.companion_id == companion_id,
                )
                .order_by(Memory.created_at.asc())
            )
            rows = list((await session.scalars(stmt)).all())
            return [
                {
                    "id": str(m.id),
                    "text": m.text,
                    "created_at": m.created_at.isoformat() if m.created_at else None,
                }
                for m in rows
            ]
    
    async def search_relevant(
        self,
        query: str,
        user_id: uuid.UUID,
        companion_id: uuid.UUID,
        limit: int = 10,
    ) -> list[dict[str, Any]]:
        """Get the most relevant memories for a query.
        
        Phase 2: Uses simple keyword matching + recency.
        Future: Replace with vector embeddings.
        """
        all_memories = await self.get_all(user_id, companion_id)
        
        if not all_memories:
            return []
        
        # Simple keyword scoring: count overlapping words (case-insensitive)
        query_words = set(w.lower() for w in query.split() if len(w) > 2)
        
        scored = []
        for m in all_memories:
            mem_words = set(w.lower() for w in m["text"].split())
            overlap = len(query_words & mem_words)
            scored.append((overlap, m))
        
        # Sort by overlap (desc), then by recency (last memories first)
        scored.sort(key=lambda x: x[0], reverse=True)
        
        # Return top N: prefer matching, but always include latest few facts
        relevant = [m for score, m in scored if score > 0][:limit]
        
        # If nothing matched, return latest facts (Maya should always have some context)
        if not relevant:
            relevant = all_memories[-min(limit, 5):]
        
        return relevant
    
    async def delete_all(
        self,
        user_id: uuid.UUID,
        companion_id: uuid.UUID,
    ) -> int:
        """Delete all memories for a user/companion pair."""
        async with self._sessionmaker() as session:
            result = await session.execute(
                delete(Memory).where(
                    Memory.user_id == user_id,
                    Memory.companion_id == companion_id,
                )
            )
            await session.commit()
            return result.rowcount or 0
